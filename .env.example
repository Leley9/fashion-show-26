# =====================================================================
#  Config du SCRIPT D'ENVOI (newsletter/send.mjs) — copie ce fichier en .env
#  .env ne doit JAMAIS être commité (voir .gitignore).
# =====================================================================

# --- Gmail (compte qui authentifie l'envoi) ---
# Active la validation en 2 étapes, puis crée un "mot de passe d'application" :
#   https://myaccount.google.com/apppasswords
GMAIL_USER=l.germanangue@gmail.com
GMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxx

# --- Adresse "From" affichée aux abonnés ---
# DOIT être envoyable par le compte ci-dessus : soit GMAIL_USER lui-même,
# soit un alias vérifié dans Gmail (Paramètres > Comptes > "Envoyer des e-mails en tant que").
# Astuce anti-spam : crée un Gmail dédié au projet (ex. purpleshow.ddw@gmail.com)
# et mets-le en GMAIL_USER + ici. Ton adresse perso reste privée.
NEWSLETTER_FROM=DDW 26 — The Purple Show <l.germanangue@gmail.com>

# --- Site & récupération des abonnés ---
SITE_URL=https://ddw26.pages.dev
EXPORT_URL=https://ddw26.pages.dev/api/export
ADMIN_TOKEN=colle_ici_le_meme_ADMIN_TOKEN_que_sur_cloudflare

# --- Doit être IDENTIQUE au secret ALTCHA_HMAC_KEY de Cloudflare ---
# (sert à signer les liens de désinscription)
ALTCHA_HMAC_KEY=colle_ici_la_meme_cle_que_sur_cloudflare

# --- Optionnel ---
# WEEK_FILE=newsletter/week.md
# SEND_DELAY_MS=1200
